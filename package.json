{
  "name": "parchment",
  "version": "0.1.0",
  "description": "Parchment — a local PDF reader and editor",
  "main": "./out/main/index.js",
  "author": "Nik Hammer-Ellis",
  "license": "MIT",
  "homepage": "https://github.com/nikhammerellis/parchment",
  "repository": {
    "type": "git",
    "url": "https://github.com/nikhammerellis/parchment.git"
  },
  "bugs": {
    "url": "https://github.com/nikhammerellis/parchment/issues"
  },
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "icons": "node scripts/generate-placeholder-icon.cjs",
    "build:win": "electron-vite build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-store": "^8.2.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.7.76",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "pngjs": "^7.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4"
  }
}
